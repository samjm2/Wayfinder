{
  "manifest_version": 3,
  "name": "Wayfinder Form Filler",
  "version": "0.2.0",
  "description": "Pre-fill government benefit forms using your Wayfinder profile. You always review before submitting.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://wayfinder.app/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Wayfinder Form Filler"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*", "https://wayfinder.app/*"],
      "js": ["dist/appBridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/portalAgent.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
